{
  "name": "platform-docs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "plugins/*",
    "mcp-server"
  ],
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "version": "docusaurus doc:version",
    "detect-secrets": "detect-secrets scan --exclude-files 'yarn.*cjs'",
    "mcp:ci": "yarn workspace @veecode-platform/docs-mcp ci",
    "mcp:build": "yarn workspace @veecode-platform/docs-mcp build",
    "snapshot:test": "yarn workspace mcp-snapshot test"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/plugin-client-redirects": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@docusaurus/theme-mermaid": "^3.9.2",
    "@mdx-js/react": "^3.0.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-copy-page-button": "0.8.4",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "docusaurus-plugin-llms": "0.5.0",
    "minisearch": "^7.1.0",
    "prism-react-renderer": "^2.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "split-md": "0.3.0"
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "yarn@4.12.0"
}
